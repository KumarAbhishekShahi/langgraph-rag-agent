# ─────────────────────────────────────────────────────────
# LangGraph Enterprise RAG Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────

# ── LLM Backend ──────────────────────────────────────────
# Options: ollama | openai | anthropic
LLM_BACKEND=ollama
LLM_MODEL=deepseek-r1:8b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (only if LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (only if LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Embedding Model ───────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_agent

# ── Text Chunking ─────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Jira ─────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_JQL=project = MYPROJECT AND updated >= -30d ORDER BY updated DESC
JIRA_MAX_RESULTS=100
# Project key where NEW issues are CREATED by the Gherkin agent
JIRA_PROJECT_KEY=MYPROJECT

# ── Confluence ────────────────────────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=your.email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
CONFLUENCE_SPACE_KEY=MYSPACE
CONFLUENCE_MAX_PAGES=50

# ── Local Paths ───────────────────────────────────────────
KB_ARTICLES_PATH=./kb_articles
SAMPLE_DATA_PATH=./sample_data
# Path to your source code repo (leave empty to skip)
# Example: C:/projects/my-spring-boot-app/src
CODEBASE_PATH=

# ── Retrieval ─────────────────────────────────────────────
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=20
RETRIEVAL_LAMBDA_MULT=0.5

# ── Scheduler ─────────────────────────────────────────────
SCHEDULE_INTERVAL_HOURS=6

# ── Gradio UI ─────────────────────────────────────────────
GRADIO_PORT=7860
GRADIO_SHARE=false
